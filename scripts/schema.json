{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Deploy Config",
  "description": "一键部署工具配置文件",
  "type": "object",
  "required": ["servers", "modules", "settings"],
  "properties": {
    "servers": {
      "type": "object",
      "description": "服务器配置",
      "additionalProperties": {
        "type": "object",
        "required": ["host", "user", "deployPath"],
        "properties": {
          "host": { "type": "string", "description": "服务器 IP 或域名" },
          "port": { "type": "integer", "default": 22, "description": "SSH 端口" },
          "user": { "type": "string", "description": "SSH 用户名" },
          "deployPath": { "type": "string", "description": "远程部署根路径" },
          "authType": { "type": "string", "enum": ["password", "key"], "default": "key" }
        }
      }
    },
    "modules": {
      "type": "object",
      "description": "模块配置",
      "additionalProperties": {
        "type": "object",
        "required": ["sourcePath", "serverPath"],
        "properties": {
          "sourcePath": { "type": "string", "description": "本地代码路径" },
          "serverPath": { "type": "string", "description": "远程子路径" },
          "composeFile": { "type": "string", "default": "docker-compose.yml" },
          "services": { "type": "array", "items": { "type": "string" } },
          "buildArgs": { "type": "object" },
          "env": { "type": "object" }
        }
      }
    },
    "settings": {
      "type": "object",
      "properties": {
        "sshKeyPath": { "type": "string", "default": "~/.ssh/id_ed25519" },
        "compressBeforeSend": { "type": "boolean", "default": true },
        "rsyncExcludes": { "type": "array", "items": { "type": "string" } },
        "defaultModule": { "type": "string", "default": "web" },
        "defaultServer": { "type": "string", "default": "production" }
      }
    }
  }
}
